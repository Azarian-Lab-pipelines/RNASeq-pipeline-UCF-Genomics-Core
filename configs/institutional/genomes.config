// =============================================================================
// Reference Genome Paths — Stokes HPC
// Location: /home/ja581385/genomics_core/configs/institutional/genomes.config
//
// All references stored on Lustre: /lustre/fs1/home/ja581385/genomics_core/references/
//
// For the first run of a new organism where indices are not yet built,
// provide only fasta and gtf. The pipeline will build indices automatically.
// Use --save_reference to save the built indices for future reuse.
//
// After building, uncomment the index paths below.
// =============================================================================

params {
    genomes {

        // =================================================================
        // Human - GRCh38 (GENCODE v44)
        // Download with:
        //   ./scripts/reference_management/download_references.sh GRCh38
        // =================================================================
        'GRCh38' {
            fasta            = '/home/ja581385/genomics_core/references/genomes/GRCh38/GRCh38.primary_assembly.genome.fa'
            gtf              = '/home/ja581385/genomics_core/references/genomes/GRCh38/gencode.v44.primary_assembly.annotation.gtf'
            gene_bed         = '/home/ja581385/genomics_core/references/genomes/GRCh38/gencode.v44.annotation.bed'
            transcript_fasta = '/home/ja581385/genomics_core/references/genomes/GRCh38/gencode.v44.transcripts.fa'

            // Pre-built indices — uncomment after building
            // Build STAR index:
            //   sbatch scripts/reference_management/build_star_index.sh GRCh38 149
            // Or let the pipeline build on first run with --save_reference
            //
            // star_index   = '/home/ja581385/genomics_core/references/indices/star/GRCh38'
            // salmon_index = '/home/ja581385/genomics_core/references/indices/salmon/GRCh38'
            // rsem_index   = '/home/ja581385/genomics_core/references/indices/rsem/GRCh38'
            // hisat2_index = '/home/ja581385/genomics_core/references/indices/hisat2/GRCh38'
        }

        // =================================================================
        // Mouse - GRCm39 (GENCODE vM33)
        // Download with:
        //   ./scripts/reference_management/download_references.sh GRCm39
        // =================================================================
        'GRCm39' {
            fasta            = '/home/ja581385/genomics_core/references/genomes/GRCm39/GRCm39.primary_assembly.genome.fa'
            gtf              = '/home/ja581385/genomics_core/references/genomes/GRCm39/gencode.vM33.primary_assembly.annotation.gtf'
            gene_bed         = '/home/ja581385/genomics_core/references/genomes/GRCm39/gencode.vM33.annotation.bed'
            transcript_fasta = '/home/ja581385/genomics_core/references/genomes/GRCm39/gencode.vM33.transcripts.fa'

            // Pre-built indices — uncomment after building
            // star_index   = '/home/ja581385/genomics_core/references/indices/star/GRCm39'
            // salmon_index = '/home/ja581385/genomics_core/references/indices/salmon/GRCm39'
        }
        
    }
}
