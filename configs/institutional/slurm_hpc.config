// =============================================================================
// Institutional SLURM Profile — Stokes HPC Cluster
// Location: /home/ja581385/genomics_core/configs/institutional/slurm_hpc.config
//
// Cluster: stokes
// Partitions: normal (default, infinite time limit)
//             preemptable (2-day time limit, jobs may be preempted)
//             highmem (2 nodes: ec325-326, for memory-intensive tasks)
// Account: tazarian
// QOS: tazarian (default), preemptable
// Max jobs per user: 250
// Filesystem: /lustre/fs1 (primary), /lustre/fs2 (secondary)
//
// The nf-core/rnaseq pipeline takes a samplesheet with FASTQ files as input,
// performs quality control, trimming and alignment, and produces a gene
// expression matrix and extensive QC report [1].
// =============================================================================

params {
    config_profile_description = 'Stokes HPC Cluster - Genomics Core SLURM Profile'
    config_profile_contact     = 'ja581385@ucf.edu'

    // ---- Cluster resource ceilings ----
    // Adjust max_cpus and max_memory after running:
    //   scontrol show node ec1 | grep -E "CPUTot|RealMemory"
    // Current estimates based on 189G devtmpfs (~380 GB RAM nodes)
    max_cpus   = 48
    max_memory = '370.GB'
    max_time   = '168.h'     // normal partition has infinite time, but cap at 7 days
}

// =============================================================================
// Singularity / Apptainer container settings
// Cluster uses Apptainer 1.3.3
// =============================================================================
singularity {
    enabled    = true
    autoMounts = true

    // Central cache for all container .img files
    cacheDir   = '/home/ja581385/genomics_core/singularity_cache'

    // CRITICAL: Bind mount all filesystem paths accessible on compute nodes
    // 
    //   /lustre/fs1  — Primary Lustre filesystem (1.2 PB, where /home lives)
    //   /lustre/fs2  — Secondary Lustre filesystem (913 TB)
    //   /tmp         — Local scratch on compute nodes
    //
    // Your home directory /home/ja581385 is on /lustre/fs1
    // so binding /lustre/fs1 covers /home as well
    runOptions = '-B /lustre/fs1 -B /lustre/fs2 -B /tmp'
}

// =============================================================================
// SLURM executor settings
// =============================================================================
executor {
    name              = 'slurm'

    // Max concurrent SLURM jobs per pipeline run
    // Your account allows 250 total — leave headroom for other jobs
    queueSize         = 100

    // Submission rate limiting to not overwhelm the SLURM scheduler
    submitRateLimit   = '10/1min'

    // Job status polling intervals
    pollInterval      = '30 sec'
    queueStatInterval = '5 min'
    exitReadTimeout   = '10 min'
}

// =============================================================================
// Process-level resource allocation
// =============================================================================
process {
    executor       = 'slurm'

    // ---- Partition and account ----
    // Primary partition: normal (infinite time limit, default)
    // Account: tazarian
    // QOS: tazarian (your default QOS)
    queue          = 'normal'
    clusterOptions = '--account=tazarian --qos=tazarian'

    // ---- Error handling with automatic retry ----
    // On OOM (137) or timeout (140), retry with escalated resources
    errorStrategy  = { task.exitStatus in [104,134,137,139,140,143,255] ? 'retry' : 'finish' }
    maxRetries     = 3
    maxErrors      = '-1'

    // ---- Default resources ----
    cpus   = { check_max( 2 * task.attempt, 'cpus' ) }
    memory = { check_max( 8.GB * task.attempt, 'memory' ) }
    time   = { check_max( 4.h * task.attempt, 'time' ) }

    // =====================================================================
    // nf-core label-based resource tiers
    // =====================================================================

    withLabel: 'process_single' {
        cpus   = { check_max( 1, 'cpus' ) }
        memory = { check_max( 6.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h * task.attempt, 'time' ) }
    }

    withLabel: 'process_low' {
        cpus   = { check_max( 4 * task.attempt, 'cpus' ) }
        memory = { check_max( 12.GB * task.attempt, 'memory' ) }
        time   = { check_max( 6.h * task.attempt, 'time' ) }
    }

    withLabel: 'process_medium' {
        cpus   = { check_max( 8 * task.attempt, 'cpus' ) }
        memory = { check_max( 36.GB * task.attempt, 'memory' ) }
        time   = { check_max( 12.h * task.attempt, 'time' ) }
    }

    withLabel: 'process_high' {
        cpus   = { check_max( 16 * task.attempt, 'cpus' ) }
        memory = { check_max( 72.GB * task.attempt, 'memory' ) }
        time   = { check_max( 24.h * task.attempt, 'time' ) }
    }

    withLabel: 'process_long' {
        time   = { check_max( 48.h * task.attempt, 'time' ) }
    }

    withLabel: 'process_high_memory' {
        // Route to highmem partition for very large memory tasks
        memory = { check_max( 128.GB * task.attempt, 'memory' ) }
        queue  = 'highmem'
        clusterOptions = '--account=tazarian --qos=tazarian'
    }

    // =====================================================================
    // Tool-specific resource overrides
    //
    // The pipeline supports multiple alignment and quantification routes:
    // STAR → Salmon (recommended), STAR → RSEM, HiSAT2 [1]
    // =====================================================================

    // ---- Genome index generation ----
    // Only runs if pre-built index is not provided
    // STAR genome generation for human needs ~32 GB RAM
    withName: 'STAR_GENOMEGENERATE' {
        cpus   = 16
        memory = { check_max( 64.GB * task.attempt, 'memory' ) }
        time   = { check_max( 24.h * task.attempt, 'time' ) }
    }

    // Salmon index generation
    withName: 'SALMON_INDEX' {
        cpus   = 12
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
        time   = { check_max( 6.h * task.attempt, 'time' ) }
    }

    // ---- Alignment ----
    // STAR is the most memory-intensive per-sample step
    // Loads entire genome index (~32 GB for human) into shared memory
    withName: 'STAR_ALIGN' {
        cpus   = 12
        memory = { check_max( 48.GB * task.attempt, 'memory' ) }
        time   = { check_max( 12.h * task.attempt, 'time' ) }
    }

    // HiSAT2 alignment (lighter than STAR)
    // Note: Quantification isn't performed with hisat2 aligner [1]
    withName: 'HISAT2_ALIGN' {
        cpus   = 8
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h * task.attempt, 'time' ) }
    }

    // ---- Quantification ----
    withName: 'SALMON_QUANT' {
        cpus   = 8
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 6.h * task.attempt, 'time' ) }
    }

    withName: 'RSEM_CALCULATEEXPRESSION' {
        cpus   = 12
        memory = { check_max( 48.GB * task.attempt, 'memory' ) }
        time   = { check_max( 24.h * task.attempt, 'time' ) }
    }

    // ---- Read QC ----
    withName: 'FASTQC' {
        cpus   = 2
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 6.h * task.attempt, 'time' ) }
    }

    // ---- Trimming ----
    // Adapter and quality trimming with Trim Galore [1]
    withName: 'TRIMGALORE' {
        cpus   = 4
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h * task.attempt, 'time' ) }
    }

    // ---- rRNA removal ----
    // SortMeRNA for ribosomal RNA removal [1]
    withName: 'SORTMERNA' {
        cpus   = 8
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h * task.attempt, 'time' ) }
    }

    // ---- Contamination detection ----
    // Kraken2 on unaligned sequences (optional) [1]
    // Standard database needs ~60-72 GB RAM
    // Route to highmem partition if standard nodes don't have enough
    withName: 'KRAKEN2_KRAKEN2' {
        cpus   = 8
        memory = { check_max( 72.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h * task.attempt, 'time' ) }
    }

    // ---- Alignment QC ----
    // Qualimap is memory-hungry [1]
    withName: 'QUALIMAP_RNASEQ' {
        cpus   = 4
        memory = { check_max( 32.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h * task.attempt, 'time' ) }
    }

    // Duplicate read marking with picard [1]
    withName: 'PICARD_MARKDUPLICATES' {
        cpus   = 2
        memory = { check_max( 24.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h * task.attempt, 'time' ) }
    }

    // RSeQC quality control suite [1]
    withName: 'RSEQC_.*' {
        cpus   = 2
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 6.h * task.attempt, 'time' ) }
    }

    // dupRadar duplication rate analysis [1]
    withName: 'DUPRADAR' {
        cpus   = 2
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 6.h * task.attempt, 'time' ) }
    }

    // Preseq library complexity estimation [1]
    withName: 'PRESEQ_LCEXTRAP' {
        cpus   = 2
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 6.h * task.attempt, 'time' ) }
    }

    // DESeq2 QC — PCA and sample clustering [1]
    withName: 'DESEQ2_QC' {
        cpus   = 2
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h * task.attempt, 'time' ) }
    }

    // ---- Report generation ----
    // MultiQC aggregated QC report [1]
    withName: 'MULTIQC' {
        cpus   = 2
        memory = { check_max( 12.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h * task.attempt, 'time' ) }
    }

    // ---- Transcript assembly ----
    // StringTie for transcript assembly and quantification [1]
    withName: 'STRINGTIE_STRINGTIE' {
        cpus   = 4
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h * task.attempt, 'time' ) }
    }

    // ---- Alignment processing ----
    // SAMtools sort and index [1]
    withName: 'SAMTOOLS_SORT' {
        cpus   = 4
        memory = { check_max( 12.GB * task.attempt, 'memory' ) }
        time   = { check_max( 8.h * task.attempt, 'time' ) }
    }

    withName: 'SAMTOOLS_INDEX' {
        cpus   = 2
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h * task.attempt, 'time' ) }
    }

    // ---- Coverage tracks ----
    // BEDTools and bedGraphToBigWig for bigWig generation [1]
    withName: 'BEDTOOLS_GENOMECOV' {
        cpus   = 2
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 4.h * task.attempt, 'time' ) }
    }

    // ---- Feature counting ----
    withName: 'SUBREAD_FEATURECOUNTS' {
        cpus   = 4
        memory = { check_max( 8.GB * task.attempt, 'memory' ) }
        time   = { check_max( 6.h * task.attempt, 'time' ) }
    }
}

// =============================================================================
// Execution reports — generated for every run
// =============================================================================
report {
    enabled   = true
    overwrite = true
}

timeline {
    enabled   = true
    overwrite = true
}

trace {
    enabled   = true
    overwrite = true
    fields    = 'task_id,hash,native_id,process,tag,name,status,exit,module,container,cpus,time,disk,memory,attempt,submit,start,complete,duration,realtime,queue,%cpu,%mem,rss,vmem,peak_rss,peak_vmem,rchar,wchar'
}

dag {
    enabled   = true
    overwrite = true
}
