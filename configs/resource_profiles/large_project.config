// =============================================================================
// Resource Profile: Large Project (100+ samples)
// Cluster: stokes | Account: tazarian | QOS: tazarian
//
// Maximum throughput for large-scale projects.
// Uses up to 150 concurrent jobs (out of 250 account limit).
// Best run during off-peak hours.
// =============================================================================

executor {
    queueSize       = 150
    submitRateLimit = '15/1min'
}

process {
    // Allow STAR more time when many samples queue simultaneously
    withName: 'STAR_ALIGN' {
        time = { check_max( 16.h * task.attempt, 'time' ) }
    }

    // MultiQC with 100+ samples needs more memory
    withName: 'MULTIQC' {
        memory = { check_max( 16.GB * task.attempt, 'memory' ) }
    }
}
