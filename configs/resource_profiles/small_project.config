// =============================================================================
// Resource Profile: Small Project (<20 samples)
// Cluster: stokes | Account: tazarian | QOS: tazarian
//
// Conservative resource usage for pilot experiments.
// Max 30 concurrent jobs — leaves plenty of room for other work.
// =============================================================================

executor {
    queueSize       = 30
    submitRateLimit = '5/1min'
}

process {
    // Use slightly fewer CPUs per task to improve queue wait times
    withName: 'STAR_ALIGN' {
        cpus   = 8
        memory = { check_max( 40.GB * task.attempt, 'memory' ) }
    }

    withName: 'SALMON_QUANT' {
        cpus   = 4
    }
}
