// =============================================================================
// Resource Profile: Preemptable QOS
// Cluster: stokes | Account: tazarian | QOS: preemptable
//
// Uses the preemptable QOS which has a 2-day time limit but jobs
// may be preempted (killed and requeued) by higher-priority jobs.
//
// Good for:
//   - Non-urgent projects where queue wait time matters more than completion time
//   - When the normal QOS queue is very busy
//   - Testing and development runs
//
// The pipeline's automatic retry mechanism handles preempted jobs
// gracefully — they will be resubmitted automatically.
//
// WARNING: Max wall time is 2 days (48 hours) on preemptable partition
// =============================================================================

process {
    queue          = 'preemptable'
    clusterOptions = '--account=tazarian --qos=preemptable'

    // Cap time to preemptable limit (2 days)
    withLabel: 'process_long' {
        time = { check_max( 44.h * task.attempt, 'time' ) }
    }

    // Ensure STAR genome generation fits within 2-day limit
    withName: 'STAR_GENOMEGENERATE' {
        time = { check_max( 24.h * task.attempt, 'time' ) }
    }
}

// Add preemption signal (SIGTERM/SIGUSR1) as a retryable exit status
// so preempted jobs are automatically resubmitted
process {
    errorStrategy = { task.exitStatus in [104,134,137,139,140,143,255] ? 'retry' : 'finish' }
}

params {
    max_time = '48.h'
}
