// =============================================================================
// Resource Profile: Multi-Project (2+ pipelines running simultaneously)
// Cluster: stokes | Account: tazarian | QOS: tazarian
//
// Use when running multiple RNA-seq projects at the same time.
// Limits each pipeline to 40 concurrent jobs.
// Example: 3 projects × 40 jobs = 120 jobs (under 250 limit)
// =============================================================================

executor {
    queueSize       = 40
    submitRateLimit = '5/1min'
}
